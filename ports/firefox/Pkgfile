# Description: Mozilla web browser
# Depends on: autoconf-2.13 cbindgen dbus-glib gtk gtk3 libnotify llvm lld clang nasm nodejs nss alsa-lib python3 startup-notification unzip yasm zip

name=firefox
version=140.10.1
release=mix-1
source=(https://archive.mozilla.org/pub/firefox/releases/${version}esr/source/firefox-${version}esr.source.tar.xz
  https://www.linuxfromscratch.org/patches/blfs/svn/firefox-${version}esr-llvm_22-1.patch
  mozconfig)

  #https://www.linuxfromscratch.org/patches/blfs/svn/firefox-${version}esr-glibc-2.43.patch
  #https://www.linuxfromscratch.org/patches/blfs/svn/firefox-140.10.1esr-python_3.14_fixes-1.patch

build() {
  cd $name-$version

  # fix video functionality with ffmpeg-8.1
  sed -i '/so.61/i \  "libavcodec.so.62",' dom/media/platforms/ffmpeg/FFmpegRuntimeLinker.cpp

  # build with glibc-2.43 (see blfs)

  # build with rustc-1.95 (see blfs)
  sed '/use super::/a use core::simd::Select;' \
    -i third_party/rust/encoding_rs/src/x_user_defined.rs &&
  sed '/patch.crates-io/a encoding_rs={path="third_party/rust/encoding_rs"}' \
    -i Cargo.toml &&
  sed '/name = "encoding_rs"/,/^$/{/source/d;/checksum/d}' -i Cargo.lock

  # build with python-3.14 (see blfs)

  # fix building with llvm v22
  patch -Np1 -i ../firefox-${version}esr-llvm_22-1.patch

  # fix building with system icu
  sed -i '/VIRAMA = 47/a CLASS_CHARACTER,' intl/lwbrk/LineBreaker.cpp

  cp -v $SRC/mozconfig .

  export CC=clang CXX=clang++ AR=llvm-ar NM=llvm-nm RANLIB=llvm-ranlib
  export MACH_BUILD_PYTHON_NATIVE_PACKAGE_SOURCE=none
  export MOZBUILD_STATE_PATH=${PWD}/mozbuild
  export MOZ_NOSPAM=1

  ./mach configure
  ./mach build
  DESTDIR=$PKG ./mach install

  install -d $PKG/usr/share/pixmaps
  ln -sv /usr/lib/firefox/browser/chrome/icons/default/default128.png $PKG/usr/share/pixmaps/firefox.png

  rm -rfv $PKG/usr/lib/firefox/browser/features
  rm -fv $PKG/usr/lib/firefox/removed-files
}
